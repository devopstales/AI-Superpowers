{
    "github-docker": {
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "--name", "ai-mcp-github",
          "-e",
          "GITHUB_PERSONAL_ACCESS_TOKEN",
          "ghcr.io/github/github-mcp-server"
        ],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
        }
      }
  
}